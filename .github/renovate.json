{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>Cramraika/.github"],
  "packageRules": [
    {
      "description": "Commercial repo: prod deps NEVER auto-merge, even on patch",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": false,
      "labels": ["needs-review"]
    }
  ]
}
